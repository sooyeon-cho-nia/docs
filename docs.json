{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "캐럿 AI 헬프센터",
  "colors": {
    "primary": "#007aff",
    "light": "#007aff",
    "dark": "#007aff"
  },
  "background": {
    "decoration": "gradient"
  },
  "favicon": "/favicon.png",
  "fonts": {
    "heading": {
      "family": "Reddit Sans"
    },
    "body": {
      "family": "Reddit Sans"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "도움말",
        "icon": "book-open",
        "pages": [
          "index",
          "help/getting-started",
          "help/account-billing",
          "help/image-generation",
          "help/workspace-settings",
          "help/sharing-collaboration",
          "help/troubleshooting"
        ]
      },
      {
        "group": "가이드",
        "icon": "compass",
        "pages": [
          "guides/overview",
          "guides/marketing",
          "guides/sns-content",
          "guides/education",
          "guides/commerce"
        ]
      },
      {
        "group": "캐럿 아카데미",
        "icon": "graduation-cap",
        "pages": [
          "academy/overview",
          "academy/beginner-course",
          "academy/pro-tips"
        ]
      },
      {
        "group": "API",
        "icon": "code",
        "pages": [
          "api/introduction",
          "api/authentication",
          "api/endpoints"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "캐럿 팀",
          "href": "https://team.carat.im/",
          "icon": "users"
        },
        {
          "anchor": "블로그",
          "href": "https://carat.im/blog",
          "icon": "newspaper"
        },
        {
          "anchor": "채용",
          "href": "https://carat.career.greetinghr.com/",
          "icon": "graduation-cap"
        }
      ]
    }
  },
  "appearance": {
    "default": "light"
  },
  "logo": {
    "light": "/logo/light.avif",
    "dark": "/logo/dark.svg",
    "href": "https://carat.im/"
  },
  "navbar": {
    "links": [
      {
        "label": "캐럿 AI 바로가기",
        "href": "https://caret.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "바로 생성하기",
      "href": "https://carat.im/create"
    }
  },
  "footer": {
    "socials": {
      "instagram": "https://www.instagram.com/carat.app/",
      "linkedin": "https://www.linkedin.com/company/paradotcorp/"
    }
  },
  "search": {
    "prompt": "무엇을 도와드릴까요?"
  },
  "feedback": {
    "thumbsRating": true
  }
}