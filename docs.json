      "href": "https://app.caret.ai/signup"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/caretai",
      "youtube": "https://youtube.com/@caretai",
      "discord": "https://discord.gg/caretai"
    }
  },
  "search": {
    "prompt": "무엇을 도와드릴까요..."
