        ]
      },
      {
        "group": "가이드",
        "icon": "compass",
        "pages": [
          "guides/overview",
          "guides/marketing",
          "guides/sns-content",
          "guides/education",
          "guides/commerce"
        ]
      },
      {
        "group": "캐럿 아카데미",
        "icon": "graduation-cap",
        "pages": [
          "academy/overview",
          "academy/beginner-course",
          "academy/pro-tips"
        ]
      },
      {
        "group": "API",
        "icon": "code",
        "pages": [
          "api/introduction",
          "api/authentication",
